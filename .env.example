LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=qwen2.5-7b-instruct
LM_STUDIO_API_KEY=lm-studio
# Optional. Only set this after increasing the loaded context inside LM Studio.
LM_STUDIO_CONTEXT_TOKENS=1024
LM_STUDIO_MAX_OUTPUT_TOKENS=128

# Pick one real web search provider.
# Recommended private/local option:
# SEARXNG_URL=http://127.0.0.1:8080

# Or API options:
# BRAVE_SEARCH_API_KEY=
# TAVILY_API_KEY=

# Optional deep page extraction. If unset, fetch_page/web_research use direct HTML/text cleanup.
# FIRECRAWL_API_KEY=
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# Used by Vite dev proxy. `npm run start:local` serves Eve here.
VITE_EVE_TARGET=http://127.0.0.1:4274

# raym33/r bridge. Defaults assume the ./r submodule is installed in this starter's .venv.
# R_BRIDGE_PYTHON=/absolute/path/to/.venv/bin/python
# R_BRIDGE_SCRIPT=/absolute/path/to/scripts/r_bridge.py
# R_BRIDGE_ALLOW_DANGEROUS=0
# R_BRIDGE_BLOCKED_SKILLS=android,bluetooth,clipboard,docker,gpio,power,realtime_voice,screenshot,social,ssh,voice,wifi
# Outward/irreversible tools that require user approval before running (additive; cannot be disabled).
# R_BRIDGE_GUARDED_TOOLS=email.send_email,social.social_post

# Local Lexia Spanish legal RAG service (raym33/lexia), used by lexia_* tools. Optional.
# LEXIA_BASE_URL=http://localhost:5174
# LEXIA_AGENT_TOKEN=

# Experimental secure connectors. These are disabled unless credentials are provided.
# Email supports read-only message metadata/snippets and guarded draft creation. It never sends email.
# EMAIL_PROVIDER=gmail
# GMAIL_OAUTH_ACCESS_TOKEN=
# EMAIL_PROVIDER=microsoft
# MICROSOFT_GRAPH_ACCESS_TOKEN=

# WhatsApp uses the official WhatsApp Business Cloud API, not WhatsApp Web scraping.
# prepare_reply creates local drafts without contacting Meta. Sending is guarded and disabled by default.
# WHATSAPP_CLOUD_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_VERSION=v20.0
# WHATSAPP_EXPERIMENTAL_SEND=0

# Workspace: the folder the assistant works in. Each tool run leaves a receipt
# under <workspace>/Receipts and Logs/receipts.jsonl.
# AI_NATIVE_OS_WORKSPACE=~/AI-Native-OS
# R_BRIDGE_RECEIPTS=1
# Restrict file paths to the workspace (opt-in). Add extra absolute dirs to the allowlist.
# R_BRIDGE_WORKSPACE_ONLY=1
# R_BRIDGE_WORKSPACE_ALLOW=/Users/me/Documents,/Users/me/Downloads

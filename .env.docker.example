DOCKER_LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=qwen2.5-7b-instruct
LM_STUDIO_API_KEY=lm-studio
# Optional. Only set this after increasing the loaded context inside LM Studio.
LM_STUDIO_CONTEXT_TOKENS=1024
LM_STUDIO_MAX_OUTPUT_TOKENS=128

# Optional web search providers.
# DOCKER_SEARXNG_URL=http://host.docker.internal:8080
# BRAVE_SEARCH_API_KEY=
# TAVILY_API_KEY=
# FIRECRAWL_API_KEY=
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev

R_BRIDGE_ALLOW_DANGEROUS=0
R_BRIDGE_BLOCKED_SKILLS=android,bluetooth,clipboard,docker,email,gpio,power,realtime_voice,screenshot,social,ssh,voice,wifi
